git config --global user.name "Your Name"
git config --global user.email "your@email.com"
mkdir my-project
cd my-project
git init
git status
git add .
git add index.html
git commit -m "Initial commit"
git branch feature-login
git checkout feature-login
///git checkout -b feature-login
git branch
git checkout main
git merge feature-login//take changes from feature-login and add them into your current branch
Link local repo to GitHub//git remote add origin https://github.com/username/repo-name.git
git remote -v
git push -u origin main//First push
git push origin main//for the next
git clone https://github.com/username/repo-name.git
cd repo-name///git clone = download + connect the project
///to merging branchs
git checkout -b feature-login
# make changes
git add .
git commit -m "Add login"

git checkout main
git merge feature-login
git push

////to update the branches
git pull
git fetch